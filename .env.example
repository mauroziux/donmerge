# Code Review Assistant Configuration
# Copy this file to .env and fill in your values

# ===========================================
# REQUIRED: AI Model Configuration
# ===========================================

# Codex model to use for code review
# Options: openai/gpt-5.3-codex
# Default: openai/gpt-5.3-codex
CODEX_MODEL=openai/gpt-5.3-codex

# API Key for AI provider
# For Codex, use your OpenAI API key
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ===========================================
# REQUIRED: GitHub Webhook + GitHub App Configuration
# ===========================================

# Webhook secret configured in the source repository webhook settings
GITHUB_WEBHOOK_SECRET=change-me

# GitHub App ID
GITHUB_APP_ID=123456

# GitHub App private key (PEM)
# For .env use escaped newlines (\n), for Wrangler secret paste full PEM
GITHUB_APP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Optional fallback PAT (used only when App credentials are not configured)
GITHUB_TOKEN_PAT=

# ===========================================
# OPTIONAL: Review Configuration
# ===========================================

# Base branch to compare against
# Default: main
BASE_BRANCH=develop

# Maximum number of files to review in a single PR
# Prevents timeout on large PRs
# Default: 50
MAX_REVIEW_FILES=50

# NOTE: Repository allowlist is configured in wrangler.jsonc via REPO_CONFIGS,
# not as an env var. See WEBHOOK_SETUP.md for details.
# ALLOWED_REPOS= is NOT used by the worker.

# Comment trigger tag for manual re-run on PR comments
# Default: @donmerge
REVIEW_TRIGGER=@donmerge

# Enable/disable automatic reviews on PR creation
# Set to 'false' to only trigger via REVIEW_TRIGGER comment
# Default: true
AUTO_REVIEW_ON_PR=true

# Timeout for review analysis (in seconds)
# Default: 300 (5 minutes)
REVIEW_TIMEOUT=300

# ===========================================
# OPTIONAL: Check Run Configuration
# ===========================================

# Fail the check run if critical issues are found
# Set to 'false' to always pass with warnings
# Default: true
FAIL_ON_CRITICAL=true

# ===========================================
# REQUIRED: Push API Configuration
# ===========================================

# Comma-separated API keys for the push API (POST /api/v1/* endpoints).
# Key format: dm_live_* for production, dm_test_* for staging/testing.
# Live keys: 30 req/min, 200 req/hr
# Test keys: 10 req/min, 50 req/hr
# Example: dm_live_abc123def456,dm_test_xyz789ghi012
# Plaintext in wrangler.jsonc (comma-separated for multi-client support, see ADR-001)
DONMERGE_API_KEYS=

# ===========================================
# OPTIONAL: Sentry Webhook Integration
# ===========================================

# HMAC-SHA256 secret for verifying Sentry webhook signatures.
# Set this when configuring a Sentry Internal Integration pointing to
# POST https://your-donmerge-instance/webhook/sentry
# Plaintext in wrangler.jsonc (comma-separated for multi-client support, see ADR-001)
SENTRY_WEBHOOK_SECRET=

# Maps Sentry org/project slugs to GitHub repos.
# Format: "org-slug:owner/repo:branch,org-slug/project:owner/repo:branch"
# - org-slug only: matches all projects under that Sentry org
# - org-slug/project: matches a specific Sentry project (takes priority)
# Example: "my-org:my-org/my-app:main,my-org/api:my-org/api-service:develop"
SENTRY_REPO_MAP=

# GitHub token used to fetch repo code during Sentry-triggered triage.
# Can be a PAT or GitHub App installation token with repo read access.
SENTRY_GITHUB_TOKEN=

# ===========================================
# OPTIONAL: Multi-Tenant Configuration (D1)
# ===========================================

# Base64-encoded 256-bit key for encrypting tenant secrets in D1.
# Generate with: openssl rand -base64 32
# Set via: wrangler secret put TENANT_ENCRYPTION_KEY
# Required only when using D1-based multi-tenant config.
TENANT_ENCRYPTION_KEY=

# ⚠️  DEV/STAGING ONLY — DO NOT USE IN PRODUCTION
# Allow plaintext (unencrypted) secrets in the D1 secrets table.
# Useful for early staging testing before TENANT_ENCRYPTION_KEY is configured.
# Must be removed once all secrets are encrypted.
ALLOW_PLAINTEXT_SECRETS=

# ===========================================
# OPTIONAL: Advanced Settings
# ===========================================

# Custom review instructions (markdown supported)
# Added to the review prompt for domain-specific guidance
# Example: "Focus on security and performance"
CUSTOM_REVIEW_INSTRUCTIONS=

# Per-repo file filtering is configured via .donmerge files
# placed in the root of reviewed repositories (not here).
# See README-CODE-REVIEW.md → ".donmerge Configuration File" for details.

# Log level for debugging
# Options: debug, info, warn, error
# Default: info
LOG_LEVEL=info
